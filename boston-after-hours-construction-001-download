import boto3
import requests
from datetime import datetime
import json

def lambda_handler(event, context):
    # Direct CSV URL
    csv_url = 'https://data.boston.gov/dataset/bca08adc-090a-4d91-99f6-ad482c5d7ac9/resource/c66524ea-36f5-43b1-aa9c-da36d7cb8744/download/tmpfqm8nllg.csv'

    # Build filename with current date (YYYY-MM-DD)
    today = datetime.utcnow().strftime('%Y-%m-%d')
    file_name = f"Boston Buildwatch - Boston - {today} - After Hours Construction.csv"

    # S3 bucket + folder
    s3_bucket_name = 'boston-buildwatch'
    s3_folder = 'boston-after-hours-construction'
    s3_key = f"{s3_folder}/{file_name}"

    s3_client = boto3.client('s3')

    try:
        # Stream download and upload to S3
        with requests.get(csv_url, stream=True) as response:
            response.raise_for_status()
            s3_client.upload_fileobj(response.raw, s3_bucket_name, s3_key)

        return {
            'statusCode': 200,
            'body': json.dumps(f"File uploaded successfully as {s3_key}")
        }

    except Exception as e:
        raise Exception(f"Failed to download or upload file: {str(e)}")
