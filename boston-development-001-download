import boto3
import requests
from datetime import datetime
import json

def lambda_handler(event, context):
    csv_url = 'https://data.boston.gov/dataset/f9788baa-9486-4a69-8d0a-91d4b6e1ed9d/resource/32e3dc10-182d-4f51-bbd9-4c28b525f1ed/download/article_80_development_projects_website.csv'

    today = datetime.utcnow().strftime('%Y-%m-%d')
    file_name = "Boston Buildwatch - Boston - {today} - Boston Development.csv".replace("{today}", today)

    s3_bucket_name = 'boston-buildwatch'
    s3_folder_name = 'boston-development'
    s3_key = f"{s3_folder_name}/{file_name}"

    s3_client = boto3.client('s3')

    try:
        with requests.get(csv_url, stream=True) as response:
            response.raise_for_status()
            s3_client.upload_fileobj(response.raw, s3_bucket_name, s3_key)

        return {
            'statusCode': 200,
            'body': json.dumps(f'File uploaded successfully as {s3_key}')
        }

    except Exception as e:
        raise Exception(f'Failed to download or upload file: {str(e)}')
