import boto3
import pandas as pd
from io import BytesIO
from datetime import datetime, timedelta
import re
import tempfile

def lambda_handler(event, context):
    s3_bucket = 'boston-buildwatch'
    s3_prefix = 'boston-approved-building-permits/'
    required_substring = 'Approved Building Permits.csv'
    CHUNK_SIZE = 50000

    s3 = boto3.client('s3')

    # Cutoff date: 5 years ago
    cutoff_date = datetime.now() - timedelta(days=5*365)

    # --- Find most recent dated file in folder ---
    paginator = s3.get_paginator('list_objects_v2')
    pages = paginator.paginate(
        Bucket=s3_bucket,
        Prefix=s3_prefix
    )

    dated_files = []
    for page in pages:
        for obj in page.get('Contents', []):
            key = obj['Key']
            if required_substring not in key:
                continue

            match = re.search(r'\d{4}-\d{2}-\d{2}', key)
            if match:
                dated_files.append(
                    (datetime.strptime(match.group(), '%Y-%m-%d'), key)
                )

    if not dated_files:
        raise Exception('No dated Approved Building Permits files found.')

    latest_date, file_key = max(dated_files, key=lambda x: x[0])

    # --- Stream CSV from S3 ---
    obj = s3.get_object(Bucket=s3_bucket, Key=file_key)
    csv_bytes = obj['Body'].read()

    csv_stream = BytesIO(csv_bytes)
    chunks = pd.read_csv(csv_stream, chunksize=CHUNK_SIZE)

    total_rows = 0
    deleted_rows = 0
    header_written = False

    # --- Use a temporary file to store filtered data ---
    with tempfile.NamedTemporaryFile(mode='w+', delete=False) as tmp_file:
        tmp_filename = tmp_file.name

        for chunk in chunks:
            total_rows += len(chunk)

            # Convert issued_date to datetime
            chunk['issued_date'] = pd.to_datetime(
                chunk['issued_date'].str[:10], errors='coerce'
            )

            keep_mask = chunk['issued_date'] >= cutoff_date
            deleted_rows += (~keep_mask).sum()
            filtered_chunk = chunk[keep_mask]

            if not filtered_chunk.empty:
                filtered_chunk.to_csv(
                    tmp_file,
                    index=False,
                    header=not header_written,
                    mode='a'
                )
                header_written = True

    # --- Upload filtered CSV back to SAME file in SAME folder ---
    with open(tmp_filename, 'rb') as f:
        s3.put_object(
            Bucket=s3_bucket,
            Key=file_key,
            Body=f,
            ContentType='text/csv'
        )

    return {
        'statusCode': 200,
        'body': (
            f'Deleted {deleted_rows} rows older than 5 years. '
            f'Kept {total_rows - deleted_rows} rows. '
            f'File: {file_key}'
        )
    }
